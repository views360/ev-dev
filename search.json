---
layout: none
---
[
  {%- assign items = site.pages | concat: site.posts -%}
  {%- assign first_item = true -%}
  {%- for item in items -%}
    {%- if item.title -%}
      {%- unless first_item -%},{%- endunless -%}
      {
        "title": {{ item.title | jsonify }},
        "url": {{ item.url | relative_url | jsonify }},
        {%- comment -%} 1. Split by the comment marker {%- endcomment -%}
        {%- assign content_parts = item.content | split: '' -%}
        
        {%- comment -%} 2. Take the .last part and then clean it {%- endcomment -%}
        {%- assign clean_content = content_parts.last | strip_html | strip_newlines | remove: "EV Subs UK | " | remove: item.title -%}
        
        "content": {{ clean_content | jsonify }}
      }
      {%- assign first_item = false -%}
    {%- endif -%}
  {%- endfor -%}
]
